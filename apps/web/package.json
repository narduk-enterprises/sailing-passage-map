    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/seo": "^3.4.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "nuxt": "^4.3.0",
    "posthog-js": "^1.205.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@iconify-json/lucide": "^1.2.94",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.11.4",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
